# MediAssist Local Development Environment
# Week 2 MVP - Testing configuration

# ===== LLM API (required for agents, but can use mock for testing) =====
GOOGLE_API_KEY=test-key-for-mvp-testing

# ===== LLM Settings =====
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=30

# ===== LangSmith =====
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=mediassist-dev

# ===== Clinical Settings =====
RISK_THRESHOLD=0.7
AUTO_APPROVE_LOW_RISK=false

# ===== HITL Settings =====
HITL_TIMEOUT_MINUTES=30
ESCALATE_ON_TIMEOUT=true

# ===== Tool Timeouts =====
TOOL_TIMEOUT_SECONDS=10
OCR_TIMEOUT_SECONDS=15
DATABASE_TIMEOUT_SECONDS=5

# ===== Workflow Settings =====
MAX_RETRIES=2
ERROR_ACCUMULATION_LIMIT=10

# ===== Logging =====
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# ===== DATABASE =====
# For Week 2 MVP, can use mock database if PostgreSQL not available
# Real PostgreSQL example:
# DATABASE_URL=postgresql://admin:admin@localhost:5432/mediassist
DATABASE_URL=postgresql://admin:admin@localhost:5432/mediassist

# ===== API Settings =====
API_HOST=127.0.0.1
API_PORT=8000

# ===== Feature Flags =====
ENABLE_GEMINI_VISION=true
ENABLE_RAG_LAYER=false
ENABLE_AUDIT_LOG=true
